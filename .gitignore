# Build output
/target/
**/target/

# Environment / secrets
.env
.env.*
!.env.example

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Cargo lock (keep for binaries, ignore for libs — adjust if needed)
# Cargo.lock  ← intentionally not ignored (workspace has binaries)

.that-agent/state/
.that/

# Local task tracking (Claude Code session state)
/tasks/

# Local caches (Docker buildx, etc.)
.cache/

# Kubernetes overlays — only the example template is committed.
# User-created overlays and all secret files are excluded.
deploy/k8s/overlays/*/secret.yaml
!deploy/k8s/overlays/example/

# Logs
*.log
