# that-agent environment configuration
# Copy this file to .env and fill in the values you need.
# At minimum, provide one LLM provider key.
# Never commit .env — it is gitignored.

# ── LLM Providers ────────────────────────────────────────────────────────────
# At least one key is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Agent Identity ────────────────────────────────────────────────────────────
# THAT_AGENT_NAME=my-agent
# THAT_AGENT_BOOTSTRAP_PROMPT=    # seeds Soul.md / Identity.md on first boot
# THAT_AGENT_PARENT=              # parent agent name for orchestration chains
# THAT_AGENT_ROLE=                # role label injected into the preamble

# ── Agent Behaviour ───────────────────────────────────────────────────────────
# THAT_AGENT_PROVIDER=anthropic   # anthropic | openai | openrouter
# THAT_AGENT_MODEL=               # leave blank to use provider default
# THAT_AGENT_MAX_TURNS=75
# THAT_AGENT_PROFILE=
# THAT_OPENAI_WEBSOCKET=true      # false → legacy HTTP streaming for OpenAI

# ── Channels ──────────────────────────────────────────────────────────────────
# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# HTTP adapter (REST + SSE interface)
# THAT_HTTP_PORT=8080
# THAT_HTTP_BEARER_TOKEN=         # leave blank to disable auth

# ── Sandbox — Docker (default) ────────────────────────────────────────────────
# THAT_SANDBOX_MODE=docker        # docker | kubernetes
# THAT_SANDBOX_REMOVE_ON_EXIT=0   # 1 = destroy container after run
# THAT_SANDBOX_MEMORY=2g          # container memory limit
# THAT_SANDBOX_CPU=2              # container CPU limit
# THAT_SANDBOX_SHM=1g             # shared memory size
# THAT_SANDBOX_PIDS=256           # max process count inside container

# ── Sandbox — Kubernetes ──────────────────────────────────────────────────────
# Only needed when THAT_SANDBOX_MODE=kubernetes
# THAT_TRUSTED_LOCAL_SANDBOX=0    # 1 = treat the local pod as the trust boundary
# THAT_SANDBOX_K8S_NAMESPACE=that-agent
# THAT_SANDBOX_K8S_REGISTRY=
# THAT_SANDBOX_K8S_REGISTRY_PUSH_ENDPOINT=
# THAT_K8S_REGISTRY_AUTOFIX_LOCALHOST_PORT=1
# THAT_BUILDKIT_SOURCE=buildkit_sidecar
# THAT_BUILDKIT_GC_KEEPSTORAGE_MB=4096
# THAT_BUILDKIT_WAIT_SECONDS=20
# THAT_IMAGE_BUILD_BACKEND_PREFERRED=buildkit
# THAT_DOCKER_DAEMON_WAIT_SECONDS=10
# THAT_DOCKER_DAEMON_SOURCE=host_or_injected

# ── Observability ─────────────────────────────────────────────────────────────
# PHOENIX_TRACING=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006
# PHOENIX_LOG_LEVEL=info
# PHOENIX_EXPORTER_LOG_ERRORS=false
# THAT_SHELL_EXEC_ALLOW_OTEL=0
# THAT_PROMPT_CACHE_ALERTS=0

# ── Logging ───────────────────────────────────────────────────────────────────
# RUST_LOG=info
