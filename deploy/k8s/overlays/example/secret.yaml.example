# secret.yaml is gitignored — never commit real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: that-agent-secrets
type: Opaque
stringData:
  OPENAI_API_KEY: ""
  ANTHROPIC_API_KEY: ""
  OPENROUTER_API_KEY: ""
  CLAUDE_CODE_OAUTH_TOKEN: ""
  THAT_HTTP_PORT: "8080"
  THAT_HTTP_BEARER_TOKEN: ""
  TELEGRAM_BOT_TOKEN: ""
  TELEGRAM_CHAT_ID: ""
